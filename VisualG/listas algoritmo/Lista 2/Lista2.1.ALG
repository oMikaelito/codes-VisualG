Algoritmo "terreno"

var
comprimento: real
altura: real
calculo: real

inicio
escreva("Escreva qual È o comprimento do terreno (em metros): ")
leia(comprimento)
escreva("Escreva qual È a altura do terreno (em metros): ")
leia(altura)
calculo:= (comprimento*altura)*850
escreva("O preÁo ser· de: ",calculo)

fimalgoritmo