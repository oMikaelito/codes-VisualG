algoritmo "bomdia"
var
nome: caractere
orientacao: caractere
inicio
escreval("Qual é o seu nome?")
leia(nome)
escreval("Qual é a sua orientação sexual? (F/M)")
leia(orientacao)
se orientacao = "M" entao
escreval("Bom dia senhor ", nome)
senao
escreval("bom dia senhora ", nome)
fimse
fimalgoritmo