algoritmo "calculo"
var
numero: real
maior: real
i: inteiro
inicio
escreval("Digite 5 n·meros:")
leia(numero)
maior:= numero
para i de 2 ate 5 faca
escreval("Digite o ", i, "║ n·mero:")
leia(numero)
se numero > maior entao
maior:= numero
fimse
fimpara
escreval("O maior n·mero ķ: ", maior)
fimalgoritmo
