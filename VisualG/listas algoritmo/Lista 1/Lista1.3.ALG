Algoritmo "media"

var
nota1: real
nota2: real
nota3: real
media: real

inicio
escreva("Escreva a primeira nota do aluno: ")
leia(nota1)
escreva("Escreva a segunda nota do aluno: ")
leia(nota2)
escreva("Escreva a terceira nota do aluno: ")
leia(nota3)
media:= (nota1+nota2+nota3)/3
escreva("A media do aluno foi:", media)

fimalgoritmo