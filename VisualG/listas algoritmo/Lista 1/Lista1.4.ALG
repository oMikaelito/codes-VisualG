Algoritmo "salario"

var
salario: real
horas: real
calculo: real

inicio
escreva("Escreva qual ť o seu salario: ")
leia(salario)
escreva("Escreva horas voce trabalha por dia: ")
leia(horas)
calculo:= salario/(horas*30)
escreva("Considerando um mes de 30 dias, voce ganha " calculo, "por hora")

fimalgoritmo