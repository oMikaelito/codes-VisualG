Algoritmo "exercicio2_informacoesdigitadas"

Var
nome: caractere
idade: inteiro
cidade: caractere
Inicio
escreval("Qual Õ o seu nome?")
leia(nome)
escreval("Qual sua idade?")
leia(idade)
escreval("Em que cidade vocõ mora?")
leia(cidade)
escreval("OlÃ, meu nome Õ ",nome," eu tenho",idade," anos, e moro na cidade de ",cidade)

Fimalgoritmo