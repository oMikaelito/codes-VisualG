algoritmo "exercio2_VerificaPrimo"
var
numero, i: inteiro
primo: logico
funcao EhPrimo(numero: inteiro): logico
var
i: inteiro
primo: logico
inicio
se (numero <= 1) entao
EhPrimo <- falso
retorne EhPrimo
fimse
primo <- verdadeiro
para i de 2 ate numero - 1 faca
se (numero % i = 0) entao
primo <- falso
retorne primo
fimse
fimpara
retorne primo
fimfuncao
inicio
escreva("Digite um n·mero inteiro e positivo: ")
leia(numero)
primo <- EhPrimo(numero)
se (primo) entao
escreval("O n·mero ", numero, " Ú primo.")
senao
escreval("O n·mero ", numero, " nÒo Ú primo.")
fimse
fimalgoritmo
