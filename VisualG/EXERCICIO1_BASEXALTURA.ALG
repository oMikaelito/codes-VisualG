algoritmo "exercicio1_baseXaltura"
var
base: real
altura: real
calculo: real
procedimento resultado (calculo: real)
inicio
escreval("o resultado sera de: ", base*altura)
fimprocedimento
inicio
escreval("Digite a base: ")
leia(base)
escreval("Digite a altura: ")
leia(altura)
resultado(calculo)
fimalgoritmo